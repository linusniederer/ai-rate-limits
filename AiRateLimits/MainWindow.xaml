<Window x:Class="AiRateLimits.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Rate Limits"
        Width="380" Height="480"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="#E0E0E0"
        FontFamily="Segoe UI"
        ShowInTaskbar="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="SummaryText"
                   Grid.Row="0"
                   FontSize="16" FontWeight="SemiBold"
                   Text="Loading…" />

        <TextBlock x:Name="LastUpdateText"
                   Grid.Row="1"
                   Margin="0,4,0,12"
                   FontSize="11" Foreground="#9E9E9E"
                   Text="" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ProvidersPanel" />
        </ScrollViewer>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Padding="12,6"
                    Content="Refresh now"
                    Click="RefreshButton_Click" />
            <Button x:Name="CopilotLoginButton"
                    DockPanel.Dock="Left"
                    Padding="12,6"
                    Content="GitHub Copilot Login"
                    Click="CopilotLoginButton_Click" />
            <TextBlock x:Name="CopilotStatusText"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       Foreground="#9E9E9E"
                       Text="" />
        </DockPanel>
    </Grid>
</Window>
