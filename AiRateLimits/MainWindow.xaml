<Window x:Class="AiRateLimits.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Rate Limits"
        Icon="Assets/App.ico"
        Width="424" Height="628"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True"
        ShowInTaskbar="True">

    <Border Background="{StaticResource BgBrush}"
            CornerRadius="14"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.55" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ===== Title bar ===== -->
            <Grid Grid.Row="0" Height="46" Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="18,0,0,0">
                    <Border Width="22" Height="22" CornerRadius="6"
                            Background="{StaticResource AccentBrush}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom" Margin="0,0,0,5">
                            <Border Width="3" Height="6" CornerRadius="1.5" Background="White" Margin="1,0" />
                            <Border Width="3" Height="10" CornerRadius="1.5" Background="White" Margin="1,0" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="AI Rate Limits" Margin="10,0,0,0"
                               VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button x:Name="SettingsButton" Style="{StaticResource ChromeButton}"
                            Click="Settings_Click" ToolTip="Settings">
                        <Path Data="{StaticResource IconSettings}" Fill="{StaticResource TextSecondaryBrush}"
                              Stretch="Uniform" Width="16" Height="16" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}" Click="Minimize_Click" ToolTip="Minimize">
                        <Path Data="{StaticResource IconMinimize}" Fill="{StaticResource TextSecondaryBrush}"
                              Stretch="Uniform" Width="14" Height="14" />
                    </Button>
                    <Button Style="{StaticResource CloseButton}" Click="Close_Click" ToolTip="Close">
                        <Path Data="{StaticResource IconClose}" Stroke="{StaticResource TextSecondaryBrush}"
                              StrokeThickness="1.6" Stretch="Uniform" Width="12" Height="12" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== Body: main view ===== -->
            <Grid x:Name="MainView" Grid.Row="1" Margin="18,2,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Status header (+ optional update banner) -->
                <StackPanel Grid.Row="0">
                <Border x:Name="UpdateBanner" Background="{StaticResource AccentBrush}" CornerRadius="10"
                        Padding="12,8" Margin="0,0,0,10" Cursor="Hand" Visibility="Collapsed"
                        MouseLeftButtonUp="UpdateBanner_Click">
                    <TextBlock x:Name="UpdateBannerText" Foreground="White" FontSize="12" FontWeight="SemiBold" />
                </Border>
                <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Ellipse x:Name="StatusDot" Grid.Column="0" Width="12" Height="12"
                                 VerticalAlignment="Center" Fill="{StaticResource UnknownBrush}" />

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusText" Text="Loading…" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" />
                            <TextBlock x:Name="StatusSubtitle" Text="" FontSize="11.5"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,1,0,0" />
                        </StackPanel>

                        <TextBlock x:Name="LastUpdateText" Grid.Column="2" Text="" FontSize="11"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                    </Grid>
                </Border>
                </StackPanel>

                <!-- Provider tabs -->
                <StackPanel x:Name="TabsPanel" Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,4" />

                <!-- Selected provider detail -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                    <StackPanel x:Name="DetailPanel" />
                </ScrollViewer>

                <!-- Footer -->
                <Grid Grid.Row="3" Margin="0,14,0,0">
                    <Button x:Name="RefreshButton" Style="{StaticResource IconActionButton}"
                            Width="38" Height="38" HorizontalAlignment="Right"
                            Click="RefreshButton_Click" ToolTip="Refresh now">
                        <Path Data="{StaticResource IconRefresh}" Fill="White"
                              Stretch="Uniform" Width="15" Height="15" />
                    </Button>
                </Grid>
            </Grid>

            <!-- ===== Body: compact view ===== -->
            <Grid x:Name="CompactView" Grid.Row="1" Margin="16,2,16,14" Visibility="Collapsed">
                <StackPanel x:Name="CompactPanel" />
            </Grid>

            <!-- ===== Body: settings view ===== -->
            <Grid x:Name="SettingsView" Grid.Row="1" Margin="18,2,18,18" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Settings header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Style="{StaticResource ChromeButton}" Width="30" Height="30"
                            Click="SettingsBack_Click" ToolTip="Back">
                        <Path Data="{StaticResource IconBack}" Stroke="{StaticResource TextSecondaryBrush}"
                              StrokeThickness="1.8" Stretch="Uniform" Width="13" Height="13" />
                    </Button>
                    <TextBlock Text="Settings" FontSize="16" FontWeight="SemiBold" Margin="6,0,0,0"
                               VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Margin="0,8,0,0">
                    <StackPanel>

                        <!-- Thresholds -->
                        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16,14"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Thresholds &amp; polling" FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="76" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Warning at" FontSize="12"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="% used to turn orange" FontSize="10.5"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                    <TextBox x:Name="WarningBox" Grid.Column="1" Style="{StaticResource InputBox}"
                                             TextAlignment="Right" />
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="76" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Critical at" FontSize="12"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="% used to turn red" FontSize="10.5"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                    <TextBox x:Name="CriticalBox" Grid.Column="1" Style="{StaticResource InputBox}"
                                             TextAlignment="Right" />
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="76" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Refresh every" FontSize="12"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="minutes between polls" FontSize="10.5"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                    <TextBox x:Name="RefreshBox" Grid.Column="1" Style="{StaticResource InputBox}"
                                             TextAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Startup -->
                        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16,14"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Start with Windows" FontSize="12.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="Launch minimized to the tray at sign-in" FontSize="10.5"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox x:Name="AutostartToggle" Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center" Click="AutostartToggle_Click" />
                            </Grid>
                        </Border>

                        <!-- Behaviour -->
                        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16,14"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Behaviour" FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Compact mode" FontSize="12"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Small window, status only" FontSize="10.5"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                    <CheckBox x:Name="CompactToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" />
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Exit when closing" FontSize="12"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Off = hide to tray (default)" FontSize="10.5"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                    <CheckBox x:Name="ExitOnCloseToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" />
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="76" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Notify below" FontSize="12"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="% available (empty = off)" FontSize="10.5"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                    <TextBox x:Name="NotifyBelowBox" Grid.Column="1"
                                             Style="{StaticResource InputBox}" TextAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- GitHub Copilot -->
                        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16,14"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Path Data="{StaticResource IconCopilot}" Fill="{StaticResource TextSecondaryBrush}"
                                          Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text="GitHub Copilot" FontSize="12.5" FontWeight="SemiBold"
                                               Margin="8,0,0,0" Foreground="{StaticResource TextBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Enterprise host (optional)" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5" />
                                <TextBox x:Name="CopilotHostBox" Style="{StaticResource InputBox}"
                                         Margin="0,0,0,12" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CopilotStatusText" Grid.Column="0" Text="" FontSize="11"
                                               VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button x:Name="CopilotLoginButton" Grid.Column="1"
                                            Style="{StaticResource GhostButton}" Padding="12,7"
                                            Click="CopilotLoginButton_Click">
                                        <TextBlock x:Name="CopilotLoginLabel" Text="Sign in" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- JetBrains -->
                        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16,14"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Path Data="{StaticResource IconJetBrains}" Fill="{StaticResource TextSecondaryBrush}"
                                          Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text="JetBrains AI" FontSize="12.5" FontWeight="SemiBold"
                                               Margin="8,0,0,0" Foreground="{StaticResource TextBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="IDE config path (optional)" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5" />
                                <TextBox x:Name="JetBrainsPathBox" Style="{StaticResource InputBox}" />
                            </StackPanel>
                        </Border>

                        <!-- About -->
                        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16,14"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock x:Name="AboutVersionText" Text="AI Rate Limits"
                                               FontSize="12.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="MIT License" FontSize="10.5"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource GhostButton}" Padding="12,7"
                                        VerticalAlignment="Center" Click="OpenRepo_Click">
                                    <TextBlock Text="GitHub" />
                                </Button>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <Button x:Name="SaveButton" Grid.Row="2" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch" Margin="0,12,0,0" Click="SaveSettings_Click">
                    <TextBlock Text="Save settings" HorizontalAlignment="Center" />
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
